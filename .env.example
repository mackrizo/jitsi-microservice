# ============================================
# JITSI MICROSERVICE - Environment Variables
# ============================================

# Server
PORT=3000
NODE_ENV=development

# --- MODE ---
# 'public'  => utilise meet.jit.si (gratuit, no auth)
# 'private' => utilise votre instance Hostinger
JITSI_MODE=public

# --- PUBLIC INSTANCE (meet.jit.si) ---
JITSI_PUBLIC_URL=https://meet.jit.si

# --- PRIVATE INSTANCE (Hostinger) ---
# L'URL de votre instance Jitsi auto-hébergée
JITSI_PRIVATE_URL=https://jitsi.yourdomain.com
# App ID défini dans votre config Jitsi (prosody/config.js)
JITSI_APP_ID=visiodoc
# Secret JWT partagé avec Jitsi (prosody token)
JITSI_APP_SECRET=your-secret-key-here
# Durée de validité du JWT en secondes (1h par défaut)
JITSI_JWT_TTL=3600

# --- API Security ---
# Clé API pour sécuriser les appels entrants au microservice
API_KEY=your-internal-api-key

# --- CORS ---
# Origines autorisées (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080,https://visiodoc.app
